# ==========================================
# CONFIGURAÇÃO DO CRM-CLINICA
# ==========================================

# URL base da API do CRM (obrigatório para integração)
# Desenvolvimento local: http://localhost:5000
# Produção: https://fono-inova-crm-back.onrender.com
VITE_CRM_API_URL=http://localhost:5000

# Chave de API (opcional - se o CRM usar autenticação)
# Deixe vazio se o endpoint /api/leads/from-website for público
VITE_CRM_API_KEY=

# ==========================================
# GOOGLE ANALYTICS (já configurado no código)
# ==========================================
# Measurement ID do GA4
VITE_GA_MEASUREMENT_ID=G-N59X7PNQZZ

# Property ID do GA4 (apenas para referência - usado no backend do CRM)
# VITE_GA4_PROPERTY_ID=486036516
